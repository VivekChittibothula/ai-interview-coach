# Copy to .env.local for local development (never commit real keys).
# Vercel: set these in Project Settings → Environment Variables.

# LLM provider: "ollama" (local dev) | "gemini" (production)
LLM_PROVIDER=ollama

# --- Gemini (production) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Ollama (local development) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# --- Resume upload limits ---
MAX_RESUME_SIZE_MB=5
MAX_RESUME_TEXT_CHARS=6000

# --- ElevenLabs (planned production TTS — not wired yet) ---
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here
